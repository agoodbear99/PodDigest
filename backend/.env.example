# Anthropic API key — server-side only, never ship this in the mobile app bundle
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used only for Whisper audio transcription (episode audio fallback
# and the audio-upload tab). Leave unset to disable transcription (episodes without
# usable show notes fall back to a title-only best-guess summary instead).
OPENAI_API_KEY=sk-...

# Port the backend listens on
PORT=8787
