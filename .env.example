# Backend base URL for the app to call. Use your computer's LAN IP (not localhost)
# when testing on a physical device with Expo Go.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# RevenueCat public SDK keys (safe to expose client-side — not secrets).
# Get these from app.revenuecat.com > Project Settings > API Keys.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...
